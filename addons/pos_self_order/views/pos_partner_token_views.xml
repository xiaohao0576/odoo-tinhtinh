<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_partner_token_list" model="ir.ui.view">
        <field name="name">pos.partner.token.list</field>
        <field name="model">pos.partner.token</field>
        <field name="arch" type="xml">
            <list string="POS Partner Tokens">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="default_language_id"/>
                <field name="preset_id"/>
                <field name="pricelist_id"/>
                <field name="expires_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pos_partner_token_form" model="ir.ui.view">
        <field name="name">pos.partner.token.form</field>
        <field name="model">pos.partner.token</field>
        <field name="arch" type="xml">
            <form string="POS Partner Token">
                <header>
                    <button name="action_regenerate_token_hash"
                            type="object"
                            string="Regenerate Token"
                            class="btn-primary"
                            groups="point_of_sale.group_pos_manager"/>
                    <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="token_hash" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="config_id"/>
                            <field name="default_language_id" domain="[('id', 'in', available_language_ids)]"/>
                            <field name="preset_id"/>
                            <field name="pricelist_id" readonly="1"/>
                            <field name="printer_id"/>
                            <field name="telegram_username"/>
                            <field name="telegram_prefill_text" widget="text"/>
                        </group>
                        <group>
                            <field name="expires_at"/>
                            <field name="last_used_at" readonly="1"/>
                            <field name="last_access_ip" readonly="1"/>
                            <field name="use_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pos_partner_token_search" model="ir.ui.view">
        <field name="name">pos.partner.token.search</field>
        <field name="model">pos.partner.token</field>
        <field name="arch" type="xml">
            <search string="POS Partner Tokens">
                <field name="name"/>
                <field name="token_hash"/>
                <field name="partner_id"/>
                <field name="config_id"/>
            </search>
        </field>
    </record>

    <record id="action_pos_partner_token" model="ir.actions.act_window">
        <field name="name">Partner Tokens</field>
        <field name="res_model">pos.partner.token</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pos_partner_token_search"/>
    </record>

    <menuitem id="menu_pos_partner_token"
              name="Partner Tokens"
              parent="point_of_sale.menu_point_config_product"
              action="action_pos_partner_token"
              sequence="90"
              groups="point_of_sale.group_pos_manager"/>
</odoo>
