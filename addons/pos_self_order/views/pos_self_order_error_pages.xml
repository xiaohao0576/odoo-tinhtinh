<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="friendly_not_found" name="Self Order Friendly Not Found">
        <t t-call="web.layout">
            <div class="so404-page">
                <div class="so404-card">
                    <div class="so404-head">
                        <div class="so404-status">404</div>
                        <h1 class="so404-title" t-if="is_zh">二维码暂时不可用</h1>
                        <h1 class="so404-title" t-else="">This QR Code Is Not Available</h1>
                    </div>

                    <p class="so404-lead" t-if="is_zh">
                        可能原因：二维码已失效、已停用，或与当前门店入口不匹配。
                    </p>
                    <p class="so404-lead" t-else="">
                        This may happen if the QR code is expired, revoked, or does not match this store entry.
                    </p>

                    <div class="so404-guide">
                        <h2 class="so404-guide-title" t-if="is_zh">建议你这样操作</h2>
                        <h2 class="so404-guide-title" t-else="">What You Can Do Next</h2>
                        <ol class="so404-guide-list" t-if="is_zh">
                            <li>确认你正在使用门店提供的最新二维码。</li>
                            <li>如果仍无法进入，请联系前台获取新二维码。</li>
                        </ol>
                        <ol class="so404-guide-list" t-else="">
                            <li>Make sure you are using the latest QR code provided by the store.</li>
                            <li>If this still fails, contact the staff for a new dedicated QR code.</li>
                        </ol>
                    </div>

                    <div class="so404-actions">
                        <a class="btn so404-btn-secondary" href="javascript:history.back()" t-if="is_zh">返回上一页</a>
                        <a class="btn so404-btn-secondary" href="javascript:history.back()" t-else="">Go Back</a>

                        <a class="btn so404-btn-primary" href="/" t-if="is_zh">返回首页</a>
                        <a class="btn so404-btn-primary" href="/" t-else="">Back to Home</a>
                    </div>

                    <p class="so404-footnote" t-if="is_zh">如需帮助，请向门店工作人员出示此页面。</p>
                    <p class="so404-footnote" t-else="">If needed, show this page to the store staff for assistance.</p>
                </div>
            </div>

            <style>
                .so404-page {
                    min-height: 100vh;
                    padding: 14px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background:
                        radial-gradient(120% 120% at 90% 10%, #dbeafe 0%, rgba(219, 234, 254, 0) 55%),
                        radial-gradient(100% 100% at 10% 100%, #fef3c7 0%, rgba(254, 243, 199, 0) 52%),
                        #f3f4f6;
                }
                .so404-card {
                    width: 100%;
                    max-width: 560px;
                    padding: 22px 16px;
                    background: #ffffff;
                    border-radius: 18px;
                    box-shadow: 0 14px 40px rgba(15, 23, 42, 0.12);
                    border: 1px solid #e5e7eb;
                }
                .so404-head {
                    text-align: left;
                }
                .so404-status {
                    display: inline-block;
                    padding: 5px 12px;
                    border-radius: 999px;
                    font-weight: 700;
                    font-size: 13px;
                    color: #991b1b;
                    background: #fee2e2;
                    margin-bottom: 10px;
                }
                .so404-title {
                    margin: 0;
                    font-size: 28px;
                    line-height: 1.2;
                    font-weight: 800;
                    color: #0f172a;
                }
                .so404-lead {
                    margin: 14px 0 0;
                    font-size: 15px;
                    line-height: 1.6;
                    color: #334155;
                }
                .so404-guide {
                    margin-top: 16px;
                    background: #f8fafc;
                    border: 1px solid #e2e8f0;
                    border-radius: 12px;
                    padding: 12px;
                }
                .so404-guide-title {
                    margin: 0 0 8px;
                    font-size: 14px;
                    line-height: 1.4;
                    font-weight: 700;
                    color: #0f172a;
                }
                .so404-guide-list {
                    margin: 0;
                    padding-left: 18px;
                    font-size: 14px;
                    line-height: 1.6;
                    color: #334155;
                }
                .so404-actions {
                    margin-top: 16px;
                    display: grid;
                    grid-template-columns: 1fr;
                    gap: 10px;
                }
                .so404-btn-primary {
                    background: #1d4ed8;
                    color: #ffffff;
                    border: none;
                    padding: 11px 16px;
                    border-radius: 10px;
                    font-weight: 600;
                    width: 100%;
                    text-align: center;
                }
                .so404-btn-primary:hover,
                .so404-btn-primary:focus {
                    background: #1e40af;
                    color: #ffffff;
                }
                .so404-btn-secondary {
                    background: #ffffff;
                    color: #1e293b;
                    border: 1px solid #cbd5e1;
                    padding: 11px 16px;
                    border-radius: 10px;
                    font-weight: 600;
                    width: 100%;
                    text-align: center;
                }
                .so404-btn-secondary:hover,
                .so404-btn-secondary:focus {
                    background: #f8fafc;
                    color: #0f172a;
                }
                .so404-footnote {
                    margin: 14px 2px 0;
                    font-size: 12px;
                    line-height: 1.5;
                    color: #64748b;
                    text-align: center;
                }
                @media (min-width: 768px) {
                    .so404-page {
                        padding: 24px;
                    }
                    .so404-card {
                        padding: 28px 24px;
                        border-radius: 20px;
                    }
                    .so404-title {
                        font-size: 32px;
                    }
                    .so404-lead {
                        font-size: 16px;
                    }
                    .so404-actions {
                        grid-template-columns: 1fr 1fr;
                    }
                }
            </style>
        </t>
    </template>
</odoo>
